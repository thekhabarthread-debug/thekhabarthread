rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- NEWS ----------
    // Anyone can read news (needed for the public website).
    // Only the signed-in admin account can create, edit, or delete news.
    // Exception: any visitor (even signed-out) may bump the "views"
    // counter by exactly 1 and nothing else — powers the view count
    // shown next to each article in the admin All News page.
    match /news/{newsId} {
      allow read: if true;
      allow create, delete: if request.auth != null
                   && request.auth.token.email == "thekhabarthread@gmail.com";
      allow update: if (request.auth != null
                   && request.auth.token.email == "thekhabarthread@gmail.com")
                   || (
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(["views"])
                     && request.resource.data.views == (resource.data.views == null ? 0 : resource.data.views) + 1
                   );
    }

    // ---------- ADS ----------
    // Anyone can read ads (needed to display them on the site).
    // Only the signed-in admin account can create, edit, or delete ads.
    match /ads/{adId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == "thekhabarthread@gmail.com";
    }

    // Block everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
